# 1. Backend Connection
# When testing locally, leave this empty to default to localhost.
# When deploying to Vercel, set this to your Render URL:
VITE_BACKEND_URL=https://your-gestura-backend.onrender.com

# 2. Firebase Configuration
# Go to Firebase Console -> Project Settings to find these values
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
